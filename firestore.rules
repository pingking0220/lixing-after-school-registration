rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.email in ['k79204@gmail.com']
          || exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email))
        );
    }

    function registrationWindowAllowsCreate() {
      return !exists(/databases/$(database)/documents/settings/app)
        || (
          (!('registrationOpenAt' in get(/databases/$(database)/documents/settings/app).data)
            || get(/databases/$(database)/documents/settings/app).data.registrationOpenAt == null
            || get(/databases/$(database)/documents/settings/app).data.registrationOpenAt <= request.time)
          && (!('registrationCloseAt' in get(/databases/$(database)/documents/settings/app).data)
            || get(/databases/$(database)/documents/settings/app).data.registrationCloseAt == null
            || request.time <= get(/databases/$(database)/documents/settings/app).data.registrationCloseAt)
        );
    }

    match /adminUsers/{email} {
      allow read, create, update, delete: if isAdmin();
    }

    match /registrations/{docId} {
      allow create: if registrationWindowAllowsCreate();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /registrationLookups/{lookupKey} {
      allow read, write: if false;

      match /entries/{entryId} {
        allow get, list: if true;
        allow create: if isAdmin() || (request.resource.data.keys().hasOnly([
            'registrationId',
            'studentName',
            'className',
            'registrationTerm',
            'currentGrade',
            'enrollmentGrade',
            'enrollmentBand',
            'submittedAt'
          ])
          && request.resource.data.registrationId == entryId
          && request.resource.data.submittedAt == request.time
          && registrationWindowAllowsCreate());
        allow update, delete: if isAdmin();
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
