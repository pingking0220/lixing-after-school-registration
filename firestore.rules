rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['k79204@gmail.com'];
    }

    match /registrations/{docId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /registrationLookups/{lookupKey} {
      allow read, write: if false;

      match /entries/{entryId} {
        allow get, list: if true;
        allow create: if isAdmin() || (request.resource.data.keys().hasOnly([
            'registrationId',
            'studentName',
            'className',
            'registrationTerm',
            'currentGrade',
            'enrollmentGrade',
            'enrollmentBand',
            'submittedAt'
          ])
          && request.resource.data.registrationId == entryId
          && request.resource.data.submittedAt == request.time);
        allow update, delete: if isAdmin();
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
